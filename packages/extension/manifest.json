{
  "manifest_version": 3,
  "name": "savemedia",
  "version": "0.0.3",
  "description": "Video downloader for verified direct files and plain HLS streams.",
  "minimum_chrome_version": "114",
  "permissions": ["downloads", "tabs", "offscreen", "webRequest"],
  "host_permissions": ["<all_urls>"],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content-main.js"],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": true
    },
    {
      "matches": ["<all_urls>"],
      "js": ["content-bridge.js"],
      "run_at": "document_start",
      "world": "ISOLATED",
      "all_frames": true
    }
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    },
    "default_popup": "src/popup/index.html",
    "default_title": "savemedia"
  },
  "commands": {
    "download-best": {
      "suggested_key": {
        "default": "Alt+S",
        "mac": "Alt+S"
      },
      "description": "Download highest available media quality"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["content-main.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
