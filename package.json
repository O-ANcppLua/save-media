{
  "name": "savemedia",
  "version": "0.0.1",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=22.11.0",
    "pnpm": ">=9.12.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "build:all": "pnpm -r build && pnpm --filter @savemedia/extension build:firefox",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "smoke:edge": "pnpm --filter @savemedia/extension smoke:edge",
    "smoke:firefox": "pnpm --filter @savemedia/extension smoke:firefox",
    "verify": "node scripts/verify.mjs"
  },
  "devDependencies": {
    "typescript": "^5.6.0"
  },
  "packageManager": "pnpm@9.12.0"
}
